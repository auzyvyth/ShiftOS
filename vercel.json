{
  "git": {
    "deploymentEnabled": {
      "staging": true
    }
  },
  "functions": {
    "api/ai-messages.js": {
      "maxDuration": 300
    }
  },
  "rewrites": [
    { "source": "/sitemap.xml", "destination": "/api/sitemap" },
    { "source": "/robots.txt", "destination": "/api/robots" },
    {
      "source": "(.*)",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": ".*(googlebot|google-inspectiontool|googleother|facebookexternalhit|whatsapp|telegrambot|twitterbot|discordbot|linkedinbot|bingbot|applebot|duckduckbot|slackbot|perplexitybot|gptbot|chatgpt-user|oai-searchbot|claudebot|anthropic-ai|cohere-ai|ia_archiver).*"
        }
      ],
      "destination": "/api/og?path=$1"
    },
    { "source": "(.*)", "destination": "/index.html" }
  ]
}
