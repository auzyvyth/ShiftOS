{
  "rewrites": [
    {
      "source": "(.*)",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": ".*(googlebot|facebookexternalhit|whatsapp|telegrambot|twitterbot|discordbot|linkedinbot|bingbot).*"
        }
      ],
      "destination": "/api/og"
    },
    { "source": "(.*)", "destination": "/index.html" }
  ]
}
